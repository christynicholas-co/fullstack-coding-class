
<%- include ('partials/header', {title: "-Home", body_id: "home", nav_bg:"light"}) %> 

<div class="container">
     <div class="row">
          <div class="col">
               <h1 class="text-center mt-5 pt-5">Christy's Portfolio!</h1>
          </div>
     </div>
     <!-- end row 1 -->

<div class="row">
     <% data.forEach(element => { %>
          <div class="col">
               <div class="img_container">
                    <img src=<%=element.src %> alt=<%= element.alt %>>
     </div>

     <a href=<%= element.href %> target='_blank'  >
     <h2 class="text-center mt-3 mb-5"> <%= element.content %></h2>
</a>
</div>
<% }) %> 
<!-- end row 2 -->
</div>
<!-- end container -->





<%- include ('partials/footer') %> 




